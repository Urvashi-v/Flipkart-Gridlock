{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "gridlock",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "streamlit", "run", "app.py",
        "--server.headless", "true", "--server.port", "8522",
        "--browser.gatherUsageStats", "false"],
      "port": 8522
    },
    {
      "name": "dashboard",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8540", "--directory", "outputs"],
      "port": 8540
    }
  ]
}
